{
  "name": "scn-badges-srv",
  "version": "5.4.3",
  "description": "SCN Badges Service Layer",
  "engines": {
    "node": "^22.0.0 || ^24.0.0"
  },
  "dependencies": {
    "@cloudnative/health-connect": "^2.1.0",
    "@inquirer/search": "^4.2.1",
    "@sap/logging": "^9.2.1",
    "@sap/textbundle": "^6.2.0",
    "accept-language-parser": "latest",
    "cors": "^2.8.6",
    "debug": "^4.4.3",
    "ejs": "^5.0.2",
    "event-loop-lag": "1.4.0",
    "express": "5.2.1",
    "glob": "13.0.6",
    "got": "^15.0.5",
    "lodash": "^4.18.1",
    "marked": "^16.4.0",
    "multer": "^2.1.1",
    "mustache": "^4.2.0",
    "nocache": "^4.0.0",
    "node-xlsx": "^0.24.0",
    "overload-protection": "^1.2.3",
    "serve-favicon": "^2.5.1",
    "sharp": "^0.34.5",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "text-wrapper": "^2.0.2",
    "then-request": "^6.0.2",
    "upath": "^3.0.7",
    "xml-escape": "^1.1.0"
  },
  "types": "types/index.d.ts",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "install:vue": "npm --prefix app/profile-vue install",
    "install:all": "npm install && npm run install:vue",
    "dev": "concurrently -k -n express,vue -c blue,magenta \"npm:dev:express\" \"npm:dev:vue\"",
    "dev:express": "nodemon index",
    "dev:server-only": "nodemon index",
    "dev:vue": "wait-on -t 30000 http://localhost:4000 && npm --prefix app/profile-vue run dev",
    "start": "node index",
    "types": "tsc --declaration --allowJs --emitDeclarationOnly --outDir types --skipLibCheck",
    "build:vue": "npm --prefix app/profile-vue ci && npm --prefix app/profile-vue run build",
    "test:vue": "npm --prefix app/profile-vue test"
  },
  "author": "SAP",
  "bugs": {
    "url": "https://github.com/SAP-samples/sap-community-activity-badges/issues"
  },
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.1.0",
    "eslint": "^10.4.1",
    "nodemon": "^3.1.14",
    "typescript": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "overrides": {
    "brace-expansion@5": "^5.0.6"
  }
